.ess.ESSR.load <- function(dir) {

    if (Sys.getenv(\"ESSR_TEST_LOAD_ERROR\") != \"\")
        stop('Loading failed with a nice message.')

    Rver <- .ess.ESSR.get.rver()
    ESSR <- .ess.ESSR.create.env(Rver)
