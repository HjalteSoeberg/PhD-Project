## From `tools:::get_link()`
.ess.getRdLink <- function(x) {
    pkg <- \"\"
    dest <- paste(unlist(x), collapse = \"\")

    opt <- attr(x, \"Rd_option\")
    if (!is.null(opt)) {
        if (grepl(\"^=\", opt, perl = TRUE, useBytes = TRUE)) {
            dest <- sub(\"^=\", \"\", opt)
        } else if (grepl(\":\", opt, perl = TRUE, useBytes = TRUE)) {
    	    dest <- sub(\"^[^:]*:\", \"\", opt)
            pkg <- sub(\":.*\", \"\", opt)
        } else {
            pkg <- as.character(opt)
        }
    }

    c(pkg, dest)
}

