;;; Portable global keybinding helpers

(unless (fboundp 'next-mode-buffer)
  (defun next-mode-buffer (&optional backwards)
    "Switch to the next buffer whose `major-mode' matches the current buffer.
With BACKWARDS, cycle in the opposite direction."
    (interactive "P")
    (let* ((curr-mode major-mode)
           (buffers (if backwards
                        (reverse (buffer-list))
                      (bury-buffer)
                      (buffer-list)))
           (target
            (cl-find-if
             (lambda (buf)
               (with-current-buffer buf
                 (and (eq major-mode curr-mode)
                      (not (string-prefix-p " " (buffer-name buf))))))
             buffers)))
      (if target
          (switch-to-buffer target)
        (message "No other %s buffer" curr-mode)))))

(unless (fboundp 'next-mode-buffer-backward)
  (defun next-mode-buffer-backward ()
    "Switch to the previous buffer whose `major-mode' matches this buffer."
    (interactive)
    (next-mode-buffer t)))

(unless (fboundp 'mark-line)
  (defun mark-line (arg)
    "Push the mark to the end of the current line."
    (interactive "p")
    (beginning-of-line)
    (push-mark
     (save-excursion
       (end-of-line arg)
       (point))
     nil t)))

(unless (fboundp 'mark-end-of-line)
  (defun mark-end-of-line (&optional arg)
    "Mark from point to the end of the current line."
    (interactive "p")
    (push-mark (point) nil t)
    (end-of-line (or arg 1))
    (activate-mark)))

(unless (fboundp 'comment-or-uncomment-line-or-region)
  (defun comment-or-uncomment-line-or-region (&optional arg)
    "Comment or uncomment active region, or the current nonblank line.
With ARG, uncomment instead of toggling."
    (interactive "P")
    (if (region-active-p)
        (if arg
            (uncomment-region (region-beginning) (region-end))
          (comment-or-uncomment-region (region-beginning) (region-end)))
      (while (and (not (eobp)) (looking-at "^[ \t]*$"))
        (forward-line 1))
      (let ((beg (line-beginning-position))
            (end (line-end-position)))
        (if arg
            (uncomment-region beg end)
          (comment-or-uncomment-region beg end)))
      (forward-line 1))))

(unless (fboundp 'yank-or-pop)
  (defun yank-or-pop (arg)
    "Run `yank', or `yank-pop' immediately after a yank."
    (interactive "*p")
    (if (eq last-command 'yank)
        (yank-pop arg)
      (yank arg))))

(unless (fboundp 'eg/kill-this-buffer)
