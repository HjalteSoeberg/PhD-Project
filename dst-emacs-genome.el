      (next-mode-buffer)
      (kill-buffer buf))))

(unless (fboundp 'klammer-island)
  (defun klammer-island ()
    "Wrap the following island of text in parentheses."
    (interactive)
    (insert "(")
    (re-search-forward "[^ }\t\n]*" nil t)
    (insert ")")
    (skip-syntax-backward ")")))

(unless (fboundp 'geschweifte-klammer-island)
  (defun geschweifte-klammer-island ()
    "Wrap the following island of text in braces."
    (interactive)
    (insert "{")
    (re-search-forward "[^ ,.}\t\n]*" nil t)
    (insert "}")
    (backward-char 1)))

(unless (fboundp 'string-island)
  (defun string-island ()
    "Wrap the following island of text in double quotes."
    (interactive)
    (insert "\"")
    (re-search-forward "[^ ,)\t\n]*" nil t)
    (insert "\"")
    (backward-char 2)
    (when (looking-at "]")
      (forward-char 1)
      (transpose-chars 1)
      (backward-char 3))
    (forward-char 1)))

(unless (fboundp 'dollar-island)
  (defun dollar-island ()
    "Wrap the following island of text in escaped parentheses."
    (interactive)
    (insert "\\(")
    (re-search-forward "[^ ,.\t\n]*" nil t)
    (insert "\\)")
    (backward-char 2)))

(unless (fboundp 'lige-island)
  (defun lige-island ()
    "Wrap the following island of text in equals signs."
    (interactive)
    (insert "=")
    (re-search-forward "[^ ,.\t\n]*" nil t)
    (insert "=")
    (backward-char 1)))

