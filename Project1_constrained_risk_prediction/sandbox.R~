# install.packages("numDeriv")   # if needed
library(numDeriv)
# ------------------------------------------------------------
# Helper: unpack parameter vector into per-cause pieces
# ------------------------------------------------------------
unpack_theta <- function(theta, p, K) {
  # K here means number of causes minus 1 if causes are j=0,...,K
  # so total number of causes = K+1 
  out <- vector("list", K + 1)
  block_size <- p + 1  # 1 for log_lambda_j, p for beta_j
  for (j in 0:K) {
    idx_start <- j * block_size + 1
    idx_end   <- idx_start + block_size - 1
    block <- theta[idx_start:idx_end]
    out[[j + 1]] <- list(
      log_lambda = block[1],
      lambda = exp(block[1]),
      beta = block[2:(p + 1)]
    )
  }
  out
}

# ------------------------------------------------------------
# Parametric Cox model with constant baseline hazard
# F_j(tau | x, theta_j) = 1 - exp(- lambda_j * exp(x beta_j) * tau)
# ------------------------------------------------------------
F_parametric_cox <- function(X, tau, log_lambda, beta) {
  lambda <- exp(log_lambda)
  eta <- as.vector(X %*% beta)
  1 - exp(-lambda * exp(eta) * tau)
}

# ------------------------------------------------------------
# Full objective:
# O is an N x (K+1) matrix with entries o_i(tau, j)
# X is N x p
# ------------------------------------------------------------
loss_fn <- function(theta, X, O, tau, K) {
  N <- nrow(X)
  p <- ncol(X) 
  theta_list <- unpack_theta(theta, p = p, K = K)
  total_loss <- 0
  for (j in 0:K) {
    pars <- theta_list[[j + 1]]
    pred_j <- F_parametric_cox(
      X = X,
      tau = tau,
      log_lambda = pars$log_lambda,
      beta = pars$beta
    )    
    total_loss <- total_loss + mean((pred_j - O[, j + 1])^2)
  }  
  total_loss
}

# ------------------------------------------------------------
# Numerical gradient using numDeriv
# ------------------------------------------------------------
grad_fn <- function(theta, X, O, tau, K) {
  numDeriv::grad(
    func = loss_fn,
    x = theta,
    X = X,
    O = O,
    tau = tau,
    K = K
  )
}

# ------------------------------------------------------------
# Main fitting function
# ------------------------------------------------------------
fit_parametric_cs_cox <- function(X, O, tau, start = NULL, method = "BFGS",
                                  control = list(maxit = 500, reltol = 1e-10)) {
  X <- as.matrix(X)
  O <- as.matrix(O)
  N <- nrow(X)
  p <- ncol(X)
  K <- ncol(O) - 1   # because causes are j = 0,...,K  
  # One log-lambda + p beta's per cause
  n_par <- (K + 1) * (p + 1)
  if (is.null(start)) {
    start <- rep(0, n_par)
    # start log-lambda at log(0.1) for each cause
    for (j in 0:K) {
      start[j * (p + 1) + 1] <- log(0.1)
    }
  }  
  fit <- optim(
    par = start,
    fn = loss_fn,
    gr = grad_fn,
    X = X,
    O = O,
    tau = tau,
    K = K,
    method = method,
    control = control
  )  
  fit$theta_list <- unpack_theta(fit$par, p = p, K = K)
  fit
}

# ------------------------------------------------------------
# Prediction function after fitting
# Returns an N x (K+1) matrix of F_j(tau | x, theta_j)
# ------------------------------------------------------------
predict_parametric_cs_cox <- function(fit, X_new, tau) {
  X_new <- as.matrix(X_new)
  p <- ncol(X_new)
  K <- length(fit$theta_list) - 1  
  pred <- matrix(NA_real_, nrow = nrow(X_new), ncol = K + 1)
  for (j in 0:K) {
    pars <- fit$theta_list[[j + 1]]
    pred[, j + 1] <- F_parametric_cox(
      X = X_new,
      tau = tau,
      log_lambda = pars$log_lambda,
      beta = pars$beta
    )
  }  
  colnames(pred) <- paste0("cause_", 0:K)
  pred
}

