# automatic differentiation
library(torch)
# ------------------------------------------------------------
# Example input data format
# data.frame with columns:
#   time, event, X1, X2, X3
#
# event = 0 means censored
# event = 1, 2, ..., K are causes
# ------------------------------------------------------------
# ------------------------------------------------------------
# Build target matrix O(tau)
# O[i, j] = 1(time_i <= tau and event_i == j), else 0
# j runs from 1,...,K
# ------------------------------------------------------------
make_target_matrix <- function(data, tau, K) {
  N <- nrow(data)
  O <- matrix(0, nrow = N, ncol = K)  
  for (j in 1:K) {
    O[, j] <- as.numeric(data$time <= tau & data$event == j)
  }  
  O
}

# ------------------------------------------------------------
# Torch module:
# Competing risks exponential-Cox model
#
# hazards:
#   h_j(x) = lambda_j * exp(x beta_j)
#
# CIF:
#   F_j(tau|x) = h_j(x) / sum_l h_l(x) * (1 - exp(-tau * sum_l h_l(x)))
# ------------------------------------------------------------
CompRiskCIFModel <- nn_module(
  "CompRiskCIFModel",  
  initialize = function(p, K) {
    self$p <- p
    self$K <- K    
    # beta: p x K
    self$beta <- nn_parameter(torch_zeros(p, K))    
    # log_lambda: length K, so lambda = exp(log_lambda) > 0
    self$log_lambda <- nn_parameter(torch_zeros(K))
  },  
  forward = function(X, tau) {
    # X: N x p
    # tau: scalar torch tensor    
    # eta: N x K
    eta <- X$matmul(self$beta)    
    # lambda: K
    lambda <- torch_exp(self$log_lambda)    
    # cause-specific hazards h_j(x) = lambda_j * exp(eta_ij)
    # broadcast lambda across rows
      H <- torch_exp(eta) * lambda$unsqueeze(1)
    # H is N x K    
    # total hazard: N x 1
    Hsum <- H$sum(dim = 2, keepdim = TRUE)    
    # avoid division by zero
    eps <- 1e-8
    Hsum_safe <- Hsum + eps    
    # CIF matrix: N x K
    CIF <- (H / Hsum_safe) * (1 - torch_exp(-tau * Hsum_safe))    
    CIF
  }
)

# ------------------------------------------------------------
# Training function
# ------------------------------------------------------------
fit_competing_risks_autodiff <- function(data,
                                         tau,
                                         K = NULL,
                                         lr = 0.01,
                                         n_epochs = 3000,
                                         print_every = 200,
                                         seed = 1) {
  set.seed(seed)
  torch_manual_seed(seed)  
  # infer K if not provided
  if (is.null(K)) {
    K <- max(data$event, na.rm = TRUE)
  }  
  # covariates
  x_cols <- c("X1", "X2", "X3")
  X_mat <- as.matrix(data[, x_cols])
  storage.mode(X_mat) <- "double"  
  # optional standardization for stability
  X_means <- colMeans(X_mat)
  X_sds <- apply(X_mat, 2, sd)
  X_sds[X_sds == 0] <- 1
  X_scaled <- scale(X_mat, center = X_means, scale = X_sds)  
  # target matrix O
  O_mat <- make_target_matrix(data, tau = tau, K = K)
  storage.mode(O_mat) <- "double"  
  # torch tensors
  X <- torch_tensor(X_scaled, dtype = torch_float())
  O <- torch_tensor(O_mat, dtype = torch_float())
  tau_t <- torch_tensor(as.numeric(tau), dtype = torch_float())  
  N <- nrow(X_mat)
  p <- ncol(X_mat)  
  # model
  model <- CompRiskCIFModel(p = p, K = K)  
  # optimizer
  optim <- optim_adam(model$parameters, lr = lr)  
  loss_history <- numeric(n_epochs)  
  for (epoch in 1:n_epochs) {
    optim$zero_grad()    
    # predicted CIFs at horizon tau
    Fhat <- model(X, tau_t)   # N x K    
    # squared error objective
    loss <- torch_mean((Fhat - O)$pow(2)) * K
    # multiplying by K makes this roughly match sum over causes
    # if you prefer exact mean over all entries, remove * K    
    loss$backward()
    optim$step()    
    loss_history[epoch] <- as.numeric(loss$item())    
    if (epoch %% print_every == 0) {
      cat("Epoch:", epoch, " Loss:", loss_history[epoch], "\n")
    }
  }  
  list(
    model = model,
    loss_history = loss_history,
    tau = tau,
    K = K,
    x_cols = x_cols,
    x_means = X_means,
    x_sds = X_sds
  )
}

# ------------------------------------------------------------
# Prediction function
# ------------------------------------------------------------
predict_cif <- function(fit, newdata, tau = NULL) {
  if (is.null(tau)) {
    tau <- fit$tau
  }  
  X_new <- as.matrix(newdata[, fit$x_cols])
  storage.mode(X_new) <- "double"  
  X_new_scaled <- scale(X_new,
                        center = fit$x_means,
                        scale = fit$x_sds)  
  X_t <- torch_tensor(X_new_scaled, dtype = torch_float())
  tau_t <- torch_tensor(as.numeric(tau), dtype = torch_float())  
  with_no_grad({
    pred <- fit$model(X_t, tau_t)
  })  
  as.matrix(pred$to(device = "cpu"))
}

# ------------------------------------------------------------
# Extract parameters
# ------------------------------------------------------------
extract_parameters <- function(fit) {
  beta_hat <- as.matrix(fit$model$beta$detach()$to(device = "cpu"))
  lambda_hat <- as.numeric(torch_exp(fit$model$log_lambda)$detach()$to(device = "cpu"))  
  colnames(beta_hat) <- paste0("cause_", 1:fit$K)
  rownames(beta_hat) <- fit$x_cols
  names(lambda_hat) <- paste0("cause_", 1:fit$K)  
  list(
    beta = beta_hat,
    lambda = lambda_hat
  )
}


